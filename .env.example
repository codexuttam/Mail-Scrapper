# Example environment variables for local development
# Copy this file to .env and fill in real values before running the app.

# MongoDB connection string
MONGODB_URI=mongodb+srv://user:password@cluster0.mongodb.net/mydb?retryWrites=true&w=majority

# OpenAI / Groq API key
GROQ_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Google OAuth (if using sign-in)
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# SMTP (email sending)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=no-reply@example.com
SMTP_PASS=supersecret
SMTP_SECURE=false # true if using port 465

# Optional: Puppeteer executable path (for scraping in some environments)
PUPPETEER_EXECUTABLE_PATH=/usr/bin/google-chrome

# Optional flags
SMTP_TEST=true # set to true to use nodemailer test account
MONGODB_URI=mongodb+srv://uttamrajsingh423_db_user:WJvwZaLnq6StdEVH@cluster0.tbdmyh4.mongodb.net/?appName=Cluster0
OPENAI_API_KEY=sk-...

# Puppeteer (optional) environment tweaks
# PUPPETEER_EXECUTABLE_PATH=/path/to/chrome

# SMTP (for send-email API)
# Example for an SMTP relay or Gmail SMTP (less secure apps or app passwords):
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false # true for 465, false for 587
SMTP_USER=you@example.com
SMTP_PASS=supersecret
